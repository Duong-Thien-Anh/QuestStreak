# ══════════════════════════════════════════════════════════════════
#  Lunis House — .env.local.example
#  Copy this file to .env and fill in your values for local dev.
#  NEVER commit the actual .env file.
# ══════════════════════════════════════════════════════════════════

# ── App Identity ─────────────────────────────────────────────────
# Used as the OAuth client_id and as a JWT audience label.
APP_ID=local-app

# Application secret. Used internally by signSessionToken (jose HS256).
# Must be a long, random string — at least 32 chars.
APP_SECRET=local-secret-change-me-min-32-chars

# ── JWT / Session Signing ────────────────────────────────────────
# JWT_SECRET is the canonical name used by the demo auth endpoint.
# For local dev, you can set it to the same value as APP_SECRET.
# On Render, set this to a strong random secret (openssl rand -hex 32).
JWT_SECRET=local-secret-change-me-min-32-chars

# ── Database ─────────────────────────────────────────────────────
# Local PostgreSQL (Docker):
#   DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lunis_house
# Production (Neon / Supabase / Render Postgres):
#   DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lunis_house

# ── Frontend (exposed to browser via Vite) ───────────────────────
# Backend API origin. Leave empty for local dev because Vite serves the
# backend on the same localhost origin.
VITE_API_URL=

# URL of the Kimi OAuth server (e.g. your Kimi Auth deployment).
VITE_KIMI_AUTH_URL=http://localhost:3000

# OAuth application ID shown to the browser.
VITE_APP_ID=local-app

# ── Backend Auth (Kimi) ──────────────────────────────────────────
# Kimi OAuth server URL (backend-to-backend calls).
KIMI_AUTH_URL=http://localhost:3000

# Kimi Open Platform base URL.
KIMI_OPEN_URL=http://localhost:3000

# ── Admin Bootstrapping ──────────────────────────────────────────
# The unionId of the app creator. This user is promoted to role="admin"
# on first sign-in via the Kimi/Zalo OAuth flow.
OWNER_UNION_ID=local-user

# ── Zalo Mini App Auth ───────────────────────────────────────────
# Only required when deploying as a Zalo Mini App.
# ZALO_APP_ID=your-zalo-app-id
ZALO_OPEN_API_URL=https://graph.zalo.me/v2.0/me

# ── Demo Mode (NEW) ──────────────────────────────────────────────
# Set to "true" to enable the POST /api/auth/demo endpoint.
# When enabled, three hardcoded demo users can be used for testing:
#   • demo_dom_1  (role: user  / lifestyle: dominant)
#   • demo_sub_1  (role: user  / lifestyle: submissive)
#   • demo_admin  (role: admin)
# IMPORTANT: Never set DEMO_MODE=true in a real production deployment.
DEMO_MODE=true
