# ── App ─────────────────────────────────────────────────────────
APP_ID=                   # Application ID
APP_SECRET=               # Application secret (used for JWT signing)

# ── Database ───────────────────────────────────────────────────
#   Dev (local PostgreSQL via Docker):
#     DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lunis_house
#   Production (Neon):
#     DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# ── Frontend (exposed to browser via Vite) ──────────────────────
VITE_API_URL=             # Optional. Leave empty on Vercel to use same-origin /api rewrites.
# VITE_KIMI_AUTH_URL=     # Deprecated Kimi OAuth server URL
VITE_APP_ID=              # OAuth application ID

# ── Backend (Auth) ─────────────────────────────────────────────
# KIMI_AUTH_URL=          # Deprecated Kimi OAuth server URL
# KIMI_OPEN_URL=          # Deprecated Kimi Open Platform URL

# ── Admin Role ──────────────────────────────────────────────────
OWNER_UNION_ID=           # Union ID of the app creator; this user gets role "admin" on first login

# ── Telegram Mini App Auth ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=       # Telegram bot token used to verify WebApp initData
TELEGRAM_BOT_SECRET=

# ── Zalo Mini App Auth ───────────────────────────────────────────
# ZALO_APP_ID=            # Deprecated Zalo Mini App ID
# ZALO_OPEN_API_URL=https://graph.zalo.me/v2.0/me

# ── Email / Mailer ──────────────────────────────────────────────
# Resend / Brevo: set SMTP_URL=https://api.resend.com + SMTP_API_KEY=<key>
# Leave empty to disable email (console log only in dev)
SMTP_URL=
SMTP_API_KEY=
MAIL_FROM=noreply@lunis.app
