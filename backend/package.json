{
  "name": "lunis-house-backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "esbuild api/boot.ts --platform=node --bundle --format=esm --outdir=dist --tsconfig=tsconfig.server.json --banner:js=\"import { createRequire } from 'module';const require = createRequire(import.meta.url);\"",
    "start": "node dist/boot.js",
    "check": "tsc -p tsconfig.server.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@ajayche/trpc-panel": "^2.1.0",
    "@aws-sdk/client-s3": "^3.965.0",
    "@aws-sdk/s3-request-presigner": "^3.965.0",
    "@hono/node-server": "^1.14.3",
    "@neondatabase/serverless": "^1.1.0",
    "@trpc/server": "^11.8.1",
    "cookie": "^1.1.1",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.8.3",
    "jose": "6.1.3",
    "nanoid": "^5.1.6",
    "postgres": "^3.4.9",
    "superjson": "^2.2.6",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "drizzle-kit": "^0.31.8",
    "esbuild": "^0.27.2",
    "typescript": "~5.9.3"
  }
}
